# Copy this file to .env on the server, then change every secret value.

# Public HTTP port on the server.
HTTP_PORT=39217

# Frontend sub-path. Keep the leading and trailing slash.
VITE_BASE_PATH=/avatarstar/

# MySQL
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
DB_NAME=avatarstar
DB_USER=avatarstar
DB_PASSWORD=replace-with-a-strong-db-password

# Backend auth
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Initial admin account. It is created on first backend startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Put your real frontend origin here. Do not include /avatarstar.
# Example: CORS_ORIGINS=http://45.202.249.207:39217
CORS_ORIGINS=http://localhost:39217
